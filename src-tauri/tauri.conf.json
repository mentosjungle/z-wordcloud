{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WordCloud",
  "version": "0.0.0",
  "identifier": "com.wordcloud.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "词云即刻",
        "width": 1000,
        "height": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: blob: data:; font-src 'self'; connect-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerName": "词云即刻",
        "installerIcon": "icons/icon.ico",
        "languages": [
          "SimpChinese",
          "English"
        ]
      }
    }
  }
}